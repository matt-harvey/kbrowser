{
    "name": "matt-harvey/kbrowser",
    "description": "Web UI for exploring a Kubernetes cluster from your local machine",
    "type": "project",
    "license": "Proprietary",
    "autoload": {
        "psr-4": {
            "App\\": "server/App"
        }
    },
    "authors": [
        {
            "name": "Matthew Harvey",
            "email": "software@matthewharvey.net"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-mbstring": "*",
        "nesbot/carbon": "^2.72",
        "substancephp/http": "dev-html",
        "substancephp/container": "^0.6.1",
        "monolog/monolog": "^3.10"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10"
    },
    "scripts": {
        "check:stan": "vendor/bin/phpstan analyze -c phpstan.neon"
    }
}
